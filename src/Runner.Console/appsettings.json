{
  "Runner": {
    "TasksFile": "tasks.md",
    "Model": "gemini 3.5 flash (high)",
    "DryRun": false,
    "Verbose": false,
    "WorkspacePath": ".",
    "Retry": {
      "MaxRetries": 3,
      "BackoffBaseSeconds": 5,
      "BackoffMaxSeconds": 300,
      "UseJitter": true
    },
    "Timeout": {
      "TaskTimeoutMinutes": 30,
      "SessionTimeoutMinutes": 60,
      "ModelSwitchTimeoutSeconds": 30
    },
    "Parallel": {
      "MaxWorkers": 1,
      "Mode": "Sequential"
    },
    "ModelConfig": {
      "TargetModel": "gemini 3.5 flash (high)",
      "FallbackModels": [],
      "AutoSwitchEnabled": true,
      "SwitchCommandTemplate": "--model {model}"
    },
    "Workspace": {
      "WorkspacePath": ".",
      "SolutionFile": null,
      "DetectStrategy": "Timestamp",
      "IncludePatterns": ["**/*.cs", "**/*.csproj", "**/*.md"],
      "ExcludePatterns": ["**/bin/**", "**/obj/**", "**/.git/**"]
    },
    "PromptTemplate": {
      "Template": "/goal Read {tasksFile}. Find the single checklist line that exactly matches:\n'{taskLine}'\n\nComplete ONLY that task, verifying your work before finishing.\nDo not start or touch any other task in the file, even if it seems related.\nWhen you finish, print the word 'TASK_' followed by 'COMPLETED'.\nWhen you cannot complete it, print the word 'TASK_' followed by 'FAILED'.",
      "Prefix": "",
      "Suffix": "",
      "Variables": {}
    },
    "Completion": {
      "SuccessMarkers": ["TASK_COMPLETED"],
      "FailureMarkers": ["TASK_FAILED"],
      "TimeoutMarkers": ["timed out", "timeout"],
      "CaseInsensitive": true
    },
    "Terminal": {
      "ShellPath": "cmd.exe",
      "Arguments": "/K",
      "EnvironmentVariables": {}
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  }
}
