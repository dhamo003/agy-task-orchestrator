{
  "Runner": {
    "TasksFile": "tasks.md",
    "Model": "gemini 3.5 flash (high)",
    "DryRun": false,
    "Verbose": false,
    "WorkspacePath": ".",
    "RetryFailedTasks": false,
    "Retry": {
      "MaxRetries": 3,
      "BackoffBaseSeconds": 5,
      "BackoffMaxSeconds": 300,
      "UseJitter": false
    },
    "Timeout": {
      "TaskTimeoutMinutes": 30,
      "SessionTimeoutMinutes": 60,
      "ModelSwitchTimeoutSeconds": 30,
      "SessionTeardownSeconds": 30
    },
    "ModelConfig": {
      "TargetModel": "gemini 3.5 flash (high)",
      "FallbackModels": [],
      "AutoSwitchEnabled": true,
      "SwitchCommandTemplate": "--model {model}"
    },
    "Workspace": {
      "WorkspacePath": ".",
      "SolutionFile": null,
      "DetectStrategy": "Hash",
      "IncludePatterns": [ "**/*" ],
      "ExcludePatterns": [ "**/bin/**", "**/obj/**", "**/.git/**", "**/.vs/**", "**/node_modules/**", "**/logs/**", "**/.antigravity/**" ]
    },
    "PromptTemplate": {
      "Template": "Read {tasksFile}. Focus on the task on line {lineNumber}: '{task}'. Complete ONLY this task by writing or modifying the actual source code, configuration, or test files in the workspace. DO NOT edit {tasksFile} — the orchestrator automatically manages task status in {tasksFile}. You MUST make actual code/file implementation changes in the project files. When fully finished and verified, print a final line containing exactly \"TASK_COMPLETED\" (without the quotes, no other text on that line). If unable to complete, print a final line \"TASK_FAILED: <reason>\" (without the quotes).",
      "Prefix": "",
      "Suffix": "",
      "Variables": {}
    },
    "Completion": {
      "SuccessMarkers": [ "TASK_COMPLETED" ],
      "FailureMarkers": [ "TASK_FAILED" ],
      "TimeoutMarkers": [ "timed out", "timeout" ],
      "CaseInsensitive": true
    },
    "Terminal": {
      "ShellPath": "cmd.exe",
      "Arguments": "/K",
      "EnvironmentVariables": {},
      "ExecutionMode": "Interactive",
      "AgentCommand": "agy",
      "OneShotArguments": [ "-p", "{prompt}", "--approve", "all" ]
    },
    "Verification": {
      "RequireMeaningfulDiff": true,
      "RequireCompletionMarker": true
    },
    "Build": {
      "Enabled": true,
      "SkipWhenNoProject": true,
      "RunTests": true,
      "Commands": [
        { "Name": "restore", "Command": "dotnet", "Arguments": [ "restore" ], "TimeoutMinutes": 10 },
        { "Name": "build", "Command": "dotnet", "Arguments": [ "build", "--no-restore" ], "TimeoutMinutes": 15 },
        { "Name": "test", "Command": "dotnet", "Arguments": [ "test", "--no-build" ], "TimeoutMinutes": 30 }
      ]
    },
    "Limits": {
      "PauseSeconds": 300,
      "MaxPausesPerTask": 12
    },
    "Checkpoint": {
      "Enabled": true,
      "Directory": ".antigravity",
      "CheckpointFileName": "checkpoint.json",
      "SnapshotFileName": "workspace-snapshot.json"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  }
}
